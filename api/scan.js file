export default async function handler(req, res) {
  // We wrap this in a try/catch so the app doesn't crash if the image is bad
  try {
    const { image } = JSON.parse(req.body);
    const API_KEY = process.env.AI_KEY; 

    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${API_KEY}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{
          parts: [
            { text: "Return ONLY JSON. Extract from this Uber Eats offer screenshot: {payout: number, milesToPickup: number, milesDelivery: number, waitMin: number}. If a value is missing, use null." },
            { inline_data: { mime_type: "image/jpeg", data: image } }
          ]
        }]
      })
    });

    const data = await response.json();
    const textResponse = data.candidates[0].content.parts[0].text;
    
    // This cleans up the AI response and sends it back to your phone
    res.status(200).json(JSON.parse(textResponse.replace(/```json|```/g, "")));
  } catch (error) {
    res.status(500).json({ error: "Failed to read image" });
  }
}
